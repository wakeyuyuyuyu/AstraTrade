{
  "timezone": "Asia/Shanghai",
  "main_agent_command": "python -m runtime.launcher",
  "run_on_weekdays_only": true,
  "check_interval_seconds": 30,
  "fixed_jobs": [
    {
      "name": "premarket_0830",
      "enabled": true,
      "time": "08:30",
      "trigger_reason": "盘前检查"
    },
    {
      "name": "lunch_check",
      "enabled": true,
      "time": "12:00",
      "trigger_reason": "午市检查"
    },
    {
      "name": "postmarket_review",
      "enabled": true,
      "time": "15:30",
      "trigger_reason": "盘后复盘"
    },
    {
      "name": "night_plan",
      "enabled": true,
      "time": "20:00",
      "trigger_reason": "当日记忆总结与明日计划制定"
    }
  ],
  "market_sessions": [
    {
      "start": "09:30",
      "end": "11:30",
      "interval_minutes": 10
    },
    {
      "start": "13:00",
      "end": "15:00",
      "interval_minutes": 10
    }
  ],
  "market_subagents": [
    {
      "name": "holding_follow",
      "enabled": true,
      "command": "python -m subagent.holding_follow.exec_agent"
    },
    {
      "name": "candidate_follow",
      "enabled": true,
      "command": "python -m subagent.candidate_follow.exec_agent"
    },
    {
      "name": "trading_diary",
      "enabled": true,
      "time": "19:20",
      "command": "python -m subagent.trading_diary.exec_agent"
    }
  ]
}
