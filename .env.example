# Copy this file to .env and fill in your own values.
# Never commit real API keys.

# OpenAI-compatible LLM endpoint
LLM_API_KEY=
LLM_URL=https://api.openai.com/v1
LLM_MODEL=

# Sub Agent OpenAI-compatible LLM endpoint
SUB_LLM_API_KEY=
SUB_LLM_URL=https://api.openai.com/v1
SUB_LLM_MODEL=

# MX Skills / market data / simulated trading
MX_APIKEY=
MX_API_URL=https://mkapi2.dfcfs.com/finskillshub

# Optional TradingAgents service
TRADINGAGENTS_TOKEN=
TRADINGAGENTS_API_URL=http://localhost:8000

# Optional: force dashboard-launched agent subprocesses to use this Python.
# Example: /absolute/path/to/.venv/bin/python
STOCK_AGENT_PYTHON=
